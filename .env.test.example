YUNDU_APP_NAME=Yundu
YUNDU_APP_VERSION=0.1.0-test
YUNDU_RUNTIME_MODE=self-hosted
YUNDU_SYSTEM_PLUGINS=
YUNDU_BETTER_AUTH_URL=http://127.0.0.1:3101
YUNDU_BETTER_AUTH_SECRET=development-only-yundu-better-auth-secret-change-me
YUNDU_HTTP_HOST=127.0.0.1
YUNDU_HTTP_PORT=3101
YUNDU_WEB_ORIGIN=http://127.0.0.1:4173
YUNDU_WEB_STATIC_DIR=
YUNDU_DATABASE_DRIVER=postgres
YUNDU_DATABASE_URL=postgres://postgres:postgres@localhost:5433/yundu_test
YUNDU_DATA_DIR=.yundu/test-data
YUNDU_PGLITE_DATA_DIR=.yundu/test-data/pglite
YUNDU_LOG_LEVEL=debug
YUNDU_ENV=test
YUNDU_OTEL_ENABLED=false
YUNDU_E2E_PROXY_DOCKER=false
YUNDU_SECRET_MASK=****
