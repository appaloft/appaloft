APPALOFT_APP_NAME=Appaloft
APPALOFT_APP_VERSION=0.1.0-test
APPALOFT_RUNTIME_MODE=self-hosted
APPALOFT_SYSTEM_PLUGINS=
APPALOFT_BETTER_AUTH_URL=http://127.0.0.1:3101
APPALOFT_BETTER_AUTH_SECRET=development-only-appaloft-better-auth-secret-change-me
APPALOFT_GITHUB_WEBHOOK_SECRET=
APPALOFT_HTTP_HOST=127.0.0.1
APPALOFT_HTTP_PORT=3101
APPALOFT_WEB_ORIGIN=http://127.0.0.1:4173
APPALOFT_WEB_STATIC_DIR=
APPALOFT_DATABASE_DRIVER=postgres
APPALOFT_DATABASE_URL=postgres://postgres:postgres@localhost:5433/appaloft_test
APPALOFT_DATA_DIR=.appaloft/test-data
APPALOFT_PGLITE_DATA_DIR=.appaloft/test-data/pglite
APPALOFT_LOG_LEVEL=debug
APPALOFT_ENV=test
APPALOFT_OTEL_ENABLED=false
OTEL_SERVICE_NAME=appaloft-backend-test
APPALOFT_E2E_PROXY_DOCKER=false
APPALOFT_SECRET_MASK=****
