{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useDefineForClassFields": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node", "bun-types"],
    "paths": {
      "@appaloft/core": ["./packages/core/src/index.ts"],
      "@appaloft/application": ["./packages/application/src/index.ts"],
      "@appaloft/cli-logging": ["./packages/cli-logging/src/index.ts"],
      "@appaloft/contracts": ["./packages/contracts/src/index.ts"],
      "@appaloft/i18n": ["./packages/i18n/src/index.ts"],
      "@appaloft/config": ["./packages/config/src/index.ts"],
      "@appaloft/observability": ["./packages/observability/src/index.ts"],
      "@appaloft/observability/bootstrap": ["./packages/observability/src/bootstrap.ts"],
      "@appaloft/orpc": ["./packages/orpc/src/index.ts"],
      "@appaloft/orpc/client": ["./packages/orpc/src/client.ts"],
      "@appaloft/persistence-pg": ["./packages/persistence/pg/src/index.ts"],
      "@appaloft/adapter-http-elysia": ["./packages/adapters/http-elysia/src/index.ts"],
      "@appaloft/adapter-cli": ["./packages/adapters/cli/src/index.ts"],
      "@appaloft/adapter-runtime": ["./packages/adapters/runtime/src/index.ts"],
      "@appaloft/adapter-filesystem": ["./packages/adapters/filesystem/src/index.ts"],
      "@appaloft/adapter-packaging": ["./packages/adapters/packaging/src/index.ts"],
      "@appaloft/provider-core": ["./packages/providers/core/src/index.ts"],
      "@appaloft/provider-generic-ssh": ["./packages/providers/generic-ssh/src/index.ts"],
      "@appaloft/provider-default-access-domain-sslip": [
        "./packages/providers/default-access-domain-sslip/src/index.ts"
      ],
      "@appaloft/provider-certificate-acme": ["./packages/providers/certificate-acme/src/index.ts"],
      "@appaloft/provider-edge-proxy-caddy": ["./packages/providers/edge-proxy-caddy/src/index.ts"],
      "@appaloft/provider-edge-proxy-traefik": [
        "./packages/providers/edge-proxy-traefik/src/index.ts"
      ],
      "@appaloft/provider-aliyun": ["./packages/providers/aliyun/src/index.ts"],
      "@appaloft/provider-tencent": ["./packages/providers/tencent/src/index.ts"],
      "@appaloft/integration-core": ["./packages/integrations/core/src/index.ts"],
      "@appaloft/integration-github": ["./packages/integrations/github/src/index.ts"],
      "@appaloft/integration-gitlab": ["./packages/integrations/gitlab/src/index.ts"],
      "@appaloft/plugin-sdk": ["./packages/plugins/sdk/src/index.ts"],
      "@appaloft/plugin-builtins": ["./packages/plugins/builtins/src/index.ts"],
      "@appaloft/plugin-host": ["./packages/plugins/host/src/index.ts"],
      "@appaloft/ai-mcp": ["./packages/ai/mcp/src/index.ts"],
      "@appaloft/testkit": ["./packages/testkit/src/index.ts"],
      "@appaloft/ui": ["./packages/ui/src/index.ts"]
    }
  }
}
