{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "APPALOFT_APP_NAME",
    "APPALOFT_APP_VERSION",
    "APPALOFT_RUNTIME_MODE",
    "APPALOFT_SYSTEM_PLUGINS",
    "APPALOFT_AUTH_PROVIDER",
    "APPALOFT_GITHUB_CLIENT_ID",
    "APPALOFT_DATABASE_DRIVER",
    "APPALOFT_DATABASE_URL",
    "APPALOFT_DATA_DIR",
    "APPALOFT_PGLITE_DATA_DIR",
    "APPALOFT_BETTER_AUTH_URL",
    "APPALOFT_BETTER_AUTH_SECRET",
    "APPALOFT_HTTP_HOST",
    "APPALOFT_HTTP_PORT",
    "APPALOFT_WEB_STATIC_DIR",
    "APPALOFT_WEB_ORIGIN",
    "APPALOFT_WEB_DEV_PROXY_TARGET",
    "APPALOFT_DEV_DISABLE_LOCAL_WEB_STATIC_DIR",
    "APPALOFT_LOG_LEVEL",
    "APPALOFT_ENV",
    "APPALOFT_OTEL_ENABLED",
    "APPALOFT_OTEL_SERVICE_NAME",
    "APPALOFT_OTEL_EXPORTER_OTLP_ENDPOINT",
    "OTEL_SERVICE_NAME",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "OTEL_EXPORTER_OTLP_TRACES_ENDPOINT",
    "OTEL_EXPORTER_OTLP_HEADERS",
    "OTEL_EXPORTER_OTLP_TRACES_HEADERS",
    "OTEL_TRACES_SAMPLER",
    "OTEL_TRACES_SAMPLER_ARG",
    "OTEL_SDK_DISABLED",
    "TRACE_LINK_BASE_URL",
    "TRACE_LINK_URL_TEMPLATE",
    "APPALOFT_E2E_EXTERNAL_SERVER",
    "APPALOFT_E2E_PROXY_DOCKER",
    "APPALOFT_SECRET_MASK",
    "APPALOFT_DEFAULT_ACCESS_DOMAIN_MODE",
    "APPALOFT_DEFAULT_ACCESS_DOMAIN_PROVIDER",
    "APPALOFT_DEFAULT_ACCESS_DOMAIN_ZONE",
    "APPALOFT_DEFAULT_ACCESS_DOMAIN_SCHEME"
  ],
  "globalPassThroughEnv": ["APPALOFT_GITHUB_CLIENT_SECRET"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", "build/**", "coverage/**", "test-results/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**", "test-results/**"]
    },
    "test:unit": {
      "dependsOn": ["^test:unit"],
      "outputs": ["coverage/**"]
    },
    "test:integration": {
      "dependsOn": ["^test:integration"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build", "^test:e2e"],
      "outputs": ["coverage/**", "test-results/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "cache": false
    },
    "db:status": {
      "cache": false
    }
  }
}
