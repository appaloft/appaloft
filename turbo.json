{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "YUNDU_APP_NAME",
    "YUNDU_APP_VERSION",
    "YUNDU_RUNTIME_MODE",
    "YUNDU_SYSTEM_PLUGINS",
    "YUNDU_AUTH_PROVIDER",
    "YUNDU_GITHUB_CLIENT_ID",
    "YUNDU_DATABASE_DRIVER",
    "YUNDU_DATABASE_URL",
    "YUNDU_DATA_DIR",
    "YUNDU_PGLITE_DATA_DIR",
    "YUNDU_BETTER_AUTH_URL",
    "YUNDU_BETTER_AUTH_SECRET",
    "YUNDU_HTTP_HOST",
    "YUNDU_HTTP_PORT",
    "YUNDU_WEB_STATIC_DIR",
    "YUNDU_WEB_ORIGIN",
    "YUNDU_WEB_DEV_PROXY_TARGET",
    "YUNDU_DEV_DISABLE_LOCAL_WEB_STATIC_DIR",
    "YUNDU_LOG_LEVEL",
    "YUNDU_ENV",
    "YUNDU_OTEL_ENABLED",
    "YUNDU_OTEL_SERVICE_NAME",
    "YUNDU_OTEL_EXPORTER_OTLP_ENDPOINT",
    "YUNDU_E2E_EXTERNAL_SERVER",
    "YUNDU_E2E_PROXY_DOCKER",
    "YUNDU_SECRET_MASK"
  ],
  "globalPassThroughEnv": ["YUNDU_GITHUB_CLIENT_SECRET"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", "build/**", "coverage/**", "test-results/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**", "test-results/**"]
    },
    "test:unit": {
      "dependsOn": ["^test:unit"],
      "outputs": ["coverage/**"]
    },
    "test:integration": {
      "dependsOn": ["^test:integration"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build", "^test:e2e"],
      "outputs": ["coverage/**", "test-results/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "cache": false
    },
    "db:status": {
      "cache": false
    }
  }
}
