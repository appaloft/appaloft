{
  "name": "@appaloft/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "bun run scripts/build.ts",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "bun run check",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test:unit": "vitest",
    "test": "bun run test:unit -- --run && bun run test:e2e",
    "test:e2e": "bun run test:e2e:webview",
    "test:e2e:webview": "bun run build && bun test test/e2e-webview"
  },
  "devDependencies": {
    "@appaloft/blueprint-marketplace-web": "workspace:*",
    "@appaloft/contracts": "workspace:*",
    "@appaloft/design": "workspace:*",
    "@appaloft/docs-registry": "workspace:*",
    "@appaloft/i18n": "workspace:*",
    "@appaloft/orpc": "workspace:*",
    "@appaloft/ui": "workspace:*",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.14.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/svelte-query": "^6.1.29",
    "@types/node": "^22",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "reflect-metadata": "^0.2.2",
    "shadcn-svelte": "^1.2.7",
    "simple-icons": "^16.21.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@wterm/dom": "^0.3.0"
  }
}
