{
  "name": "@appaloft/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "bun run scripts/build.ts",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "bun run check",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test:unit": "vitest",
    "test": "bun run test:unit -- --run && bun run test:e2e",
    "test:e2e": "bun run test:e2e:webview",
    "test:e2e:webview": "bun run build && bun test --max-concurrency=1 --timeout=60000 test/e2e-webview/home.webview.test.ts -t \"^(?!.*(DEP-EVENTS|RES-PROFILE-ENTRY-002\\\\] submits resource archive|ENV-LIFE|RES-PROFILE-ENTRY-008|CERT-IMPORT|QUICK-DEPLOY-ENTRY)).*$\" && bun test --max-concurrency=1 --timeout=60000 test/e2e-webview/home.webview.test.ts -t \"DEP-EVENTS|RES-PROFILE-ENTRY-002\\\\] submits resource archive|ENV-LIFE|RES-PROFILE-ENTRY-008|CERT-IMPORT|QUICK-DEPLOY-ENTRY\""
  },
  "devDependencies": {
    "@appaloft/blueprint-marketplace-web": "workspace:*",
    "@appaloft/blueprints": "workspace:*",
    "@appaloft/contracts": "workspace:*",
    "@appaloft/core": "workspace:*",
    "@appaloft/design": "workspace:*",
    "@appaloft/docs-registry": "workspace:*",
    "@appaloft/i18n": "workspace:*",
    "@appaloft/orpc": "workspace:*",
    "@appaloft/ui": "workspace:*",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.21.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/svelte-query": "^6.1.35",
    "@types/node": "^22.20.0",
    "@types/sortablejs": "^1.15.9",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "layerchart": "^1.0.13",
    "reflect-metadata": "^0.2.2",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@thesvg/icons": "^3.0.18",
    "@wterm/dom": "^0.3.0",
    "sortablejs": "^1.15.7"
  }
}
