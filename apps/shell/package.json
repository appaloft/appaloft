{
  "name": "@appaloft/shell",
  "private": true,
  "type": "module",
  "bin": {
    "appaloft": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts serve",
    "build": "bun build src/index.ts --outfile dist/appaloft --target bun",
    "lint": "biome check .",
    "typecheck": "tsgo -p tsconfig.json --noEmit --checkers 4",
    "test": "bun test",
    "test:e2e": "bun test ./test/e2e/*.e2e.ts",
    "db:migrate": "bun run src/index.ts db migrate",
    "db:status": "bun run src/index.ts db status"
  },
  "dependencies": {
    "@appaloft/adapter-cli": "workspace:*",
    "@appaloft/adapter-filesystem": "workspace:*",
    "@appaloft/adapter-http-elysia": "workspace:*",
    "@appaloft/adapter-runtime": "workspace:*",
    "@appaloft/ai-mcp": "workspace:*",
    "@appaloft/application": "workspace:*",
    "@appaloft/auth-better": "workspace:*",
    "@appaloft/config": "workspace:*",
    "@appaloft/contracts": "workspace:*",
    "@appaloft/integration-github": "workspace:*",
    "@appaloft/integration-gitlab": "workspace:*",
    "@appaloft/observability": "workspace:*",
    "@appaloft/persistence-pg": "workspace:*",
    "@appaloft/plugin-builtins": "workspace:*",
    "@appaloft/plugin-host": "workspace:*",
    "@appaloft/provider-aliyun": "workspace:*",
    "@appaloft/provider-certificate-acme": "workspace:*",
    "@appaloft/provider-default-access-domain-sslip": "workspace:*",
    "@appaloft/provider-edge-proxy-caddy": "workspace:*",
    "@appaloft/provider-edge-proxy-traefik": "workspace:*",
    "@appaloft/provider-generic-ssh": "workspace:*",
    "@appaloft/provider-local-shell": "workspace:*",
    "@appaloft/provider-tencent": "workspace:*",
    "nanoid": "^5.1.7",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  }
}
