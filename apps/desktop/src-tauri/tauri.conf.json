{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Appaloft",
  "version": "0.7.1",
  "identifier": "com.appaloft.desktop",
  "build": {
    "beforeDevCommand": {
      "cwd": "..",
      "script": "bun run prepare:sidecar",
      "wait": true
    },
    "beforeBuildCommand": {
      "cwd": "..",
      "script": "bun run prepare:sidecar"
    },
    "frontendDist": "frontend-dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/appaloft"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
