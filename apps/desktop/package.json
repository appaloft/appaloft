{
  "name": "@yundu/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "dev": "electron-vite dev",
    "lint": "biome check package.json electron.vite.config.ts src tsconfig.json",
    "package": "bun run build && electron-builder",
    "package:dir": "bun run build && electron-builder --dir",
    "preview": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "build": {
    "appId": "ai.yundu.desktop",
    "productName": "Yundu",
    "directories": {
      "output": "../../dist/release/yundu-desktop"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../dist/release/yundu-binary-bundle",
        "to": "yundu-binary-bundle",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "category": "Development",
      "target": [
        "AppImage"
      ]
    }
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0"
  }
}
