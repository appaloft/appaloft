YUNDU_APP_NAME=Yundu
YUNDU_APP_VERSION=0.1.0
YUNDU_RUNTIME_MODE=self-hosted
YUNDU_SYSTEM_PLUGINS=
YUNDU_BETTER_AUTH_URL=http://localhost:3001
YUNDU_BETTER_AUTH_SECRET=development-only-yundu-better-auth-secret-change-me
# Create a GitHub OAuth App with callback URL:
# http://localhost:3001/api/auth/callback/github
YUNDU_GITHUB_CLIENT_ID=
YUNDU_GITHUB_CLIENT_SECRET=
YUNDU_HTTP_HOST=0.0.0.0
YUNDU_HTTP_PORT=3001
YUNDU_WEB_ORIGIN=http://localhost:4173
YUNDU_WEB_STATIC_DIR=
YUNDU_DATABASE_DRIVER=pglite
# For external PostgreSQL, switch the driver and set a URL like:
# YUNDU_DATABASE_DRIVER=postgres
# YUNDU_DATABASE_URL=postgres://postgres:postgres@localhost:5432/yundu
YUNDU_DATA_DIR=.yundu/data
YUNDU_PGLITE_DATA_DIR=.yundu/data/pglite
YUNDU_LOG_LEVEL=info
YUNDU_ENV=development
YUNDU_OTEL_ENABLED=false
OTEL_SERVICE_NAME=yundu-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer%20local-token
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=1
# TRACE_LINK_BASE_URL=http://localhost:16686
# TRACE_LINK_URL_TEMPLATE=http://localhost:3301/trace/{traceId}
YUNDU_SECRET_MASK=****
