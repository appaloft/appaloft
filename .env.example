APPALOFT_APP_NAME=Appaloft
APPALOFT_APP_VERSION=0.1.0
APPALOFT_RUNTIME_MODE=self-hosted
APPALOFT_SYSTEM_PLUGINS=
APPALOFT_BETTER_AUTH_URL=http://localhost:3001
APPALOFT_BETTER_AUTH_SECRET=development-only-appaloft-better-auth-secret-change-me
# Create a GitHub OAuth App with callback URL:
# http://localhost:3001/api/auth/callback/github
APPALOFT_GITHUB_CLIENT_ID=
APPALOFT_GITHUB_CLIENT_SECRET=
APPALOFT_GITHUB_WEBHOOK_SECRET=
APPALOFT_HTTP_HOST=0.0.0.0
APPALOFT_HTTP_PORT=3001
APPALOFT_WEB_ORIGIN=http://localhost:4173
APPALOFT_WEB_STATIC_DIR=
APPALOFT_DOCS_STATIC_DIR=
APPALOFT_DATABASE_DRIVER=pglite
# For external PostgreSQL, switch the driver and set a URL like:
# APPALOFT_DATABASE_DRIVER=postgres
# APPALOFT_DATABASE_URL=postgres://postgres:postgres@localhost:5432/appaloft
APPALOFT_DATA_DIR=.appaloft/data
APPALOFT_PGLITE_DATA_DIR=.appaloft/data/pglite
APPALOFT_LOG_LEVEL=info
APPALOFT_ENV=development
APPALOFT_OTEL_ENABLED=false
OTEL_SERVICE_NAME=appaloft-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer%20local-token
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=1
# TRACE_LINK_BASE_URL=http://localhost:16686
# TRACE_LINK_URL_TEMPLATE=http://localhost:3301/trace/{traceId}
APPALOFT_SECRET_MASK=****
