{
  "name": "appaloft",
  "version": "1.2.0",
  "devDependencies": {
    "@appaloft/adapter-packaging": "workspace:*",
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^22.20.0",
    "@types/semver": "^7.7.1",
    "@typescript/native": "npm:typescript@7.0.2",
    "bun-types": "^1.3.14",
    "husky": "^9.1.7",
    "lint-staged": "17.0.8",
    "skills": "1.5.9",
    "turbo": "^2.10.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "license": "Apache-2.0",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts,json,jsonc,css,graphql,gql,html}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "bun --env-file=.env.develop --env-file=.env --env-file=.env.local --env-file=.env.develop.local turbo run dev --filter=@appaloft/web --filter=@appaloft/docs --filter=@appaloft/shell",
    "dev:all": "turbo run dev --parallel",
    "bun:version:sync": "bun run scripts/sync-bun-version.ts",
    "bun:version:check": "bun run scripts/sync-bun-version.ts --check",
    "lint": "biome check . && bun run check:ash",
    "lint:fix": "biome check --write .",
    "lint:ci": "biome ci . && bun run check:ash",
    "lint:staged": "lint-staged",
    "check:ash": "bun run scripts/check-ash-command-construction.ts",
    "typecheck": "turbo run typecheck",
    "typecheck:root": "tsc -p tsconfig.json --noEmit --checkers 4",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit && bun test scripts/test/appaloft-skill-evals.test.ts",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "format": "biome format --write .",
    "serve": "bun run --cwd apps/shell src/index.ts serve",
    "doctor": "bun run --cwd apps/shell src/index.ts doctor",
    "db:migrate": "bun run --cwd apps/shell src/index.ts db migrate",
    "db:status": "bun run --cwd apps/shell src/index.ts db status",
    "package:binary-bundle": "bun run scripts/release/build-binary-bundle.ts",
    "package:deploy-cli-bundle": "bun run scripts/release/build-deploy-cli-bundle.ts",
    "package:artifacts": "bun run scripts/release/build-artifacts.ts",
    "release:manifest": "bun run scripts/release/generate-release-manifest.ts",
    "release:notes": "bun run scripts/release/generate-release-notes.ts",
    "release:npm:prepare": "bun run scripts/release/prepare-npm-packages.ts",
    "release:homebrew": "bun run scripts/release/generate-homebrew.ts",
    "desktop:dev": "bun run package:binary-bundle && bun run --cwd apps/desktop dev",
    "desktop:package": "bun run package:binary-bundle && bun run --cwd apps/desktop package:app",
    "checksums": "bun run scripts/release/generate-checksums.ts",
    "smoke:local:commands": "bun run scripts/smoke/local-deploy.ts --method=workspace-commands --port=4310",
    "smoke:local:docker": "bun run scripts/smoke/local-deploy.ts --method=dockerfile --port=4311",
    "smoke:deployment-proof": "bun run scripts/smoke/deployment-proof.ts",
    "smoke:sandbox:docker": "bun run scripts/smoke/execution-sandbox-docker.ts",
    "smoke:deployment-route-proof": "APPALOFT_DEPLOYMENT_ROUTE_PROOF_TRAEFIK_SMOKE=1 bun test --timeout=60000 packages/adapters/runtime/test/deployment-route-proof.real-traefik.test.ts",
    "smoke:local:compose": "bun run scripts/smoke/local-deploy.ts --method=docker-compose --port=4312",
    "smoke:local:prebuilt": "bun run scripts/smoke/local-deploy.ts --method=prebuilt-image --port=4313",
    "smoke:local:static": "bun run scripts/smoke/local-deploy.ts --method=static",
    "smoke:framework:docker-fixtures": "APPALOFT_E2E_FRAMEWORK_DOCKER=true bun test --timeout=3600000 ./apps/shell/test/e2e/quick-deploy-framework-fixtures-docker.workflow.e2e.ts",
    "smoke:framework:docker-substrates": "bun test --timeout=300000 ./apps/shell/test/e2e/quick-deploy-local-docker-substrates.workflow.e2e.ts",
    "smoke:framework:docker": "bun run smoke:framework:docker-substrates && bun run smoke:framework:docker-fixtures",
    "smoke:framework:ssh": "bun run smoke:ssh:preflight && APPALOFT_E2E_SSH_FRAMEWORK_DOCKER=true bun test --timeout=1800000 ./apps/shell/test/e2e/quick-deploy-framework-fixtures-ssh.workflow.e2e.ts",
    "smoke:framework": "bun run smoke:framework:docker && bun run smoke:framework:ssh",
    "smoke:scheduled-task:docker": "APPALOFT_E2E_SCHEDULED_TASK_DOCKER=true bun test --timeout=300000 packages/adapters/runtime/test/scheduled-task-runtime.real-docker.test.ts",
    "smoke:scheduled-task:ssh": "bun run smoke:ssh:preflight && APPALOFT_E2E_SSH_SCHEDULED_TASK_DOCKER=true bun test --timeout=300000 packages/adapters/runtime/test/scheduled-task-runtime.real-docker.test.ts",
    "smoke:scheduled-task": "bun run smoke:scheduled-task:docker && bun run smoke:scheduled-task:ssh",
    "smoke:storage-cleanup:docker": "APPALOFT_E2E_STORAGE_CLEANUP_DOCKER=true bun test --timeout=300000 packages/adapters/runtime/test/storage-runtime-cleanup.test.ts",
    "smoke:storage-cleanup:ssh": "bun run smoke:ssh:preflight && APPALOFT_E2E_SSH_STORAGE_CLEANUP_DOCKER=true bun test --timeout=300000 packages/adapters/runtime/test/storage-runtime-cleanup.test.ts",
    "smoke:storage-cleanup": "bun run smoke:storage-cleanup:docker && bun run smoke:storage-cleanup:ssh",
    "smoke:storage-backup:docker": "APPALOFT_E2E_STORAGE_BACKUP_DOCKER=true bun test --timeout=300000 packages/adapters/runtime/test/storage-volume-backup-provider.test.ts",
    "smoke:storage-backup:ssh": "bun run smoke:ssh:preflight && APPALOFT_E2E_SSH_STORAGE_BACKUP_DOCKER=true bun test --timeout=300000 packages/adapters/runtime/test/storage-volume-backup-provider.test.ts",
    "smoke:storage-backup": "bun run smoke:storage-backup:docker && bun run smoke:storage-backup:ssh",
    "smoke:tunnel:cloudflare": "APPALOFT_E2E_TUNNEL_CLOUDFLARE=true bun test --timeout=120000 packages/adapters/runtime/test/tunnel-provider.real-cloudflare.test.ts",
    "smoke:runtime-usage:docker": "APPALOFT_RUNTIME_USAGE_DOCKER_SMOKE=1 bun test --timeout=300000 packages/adapters/runtime/test/runtime-usage-smoke.test.ts",
    "smoke:runtime-usage:ssh": "bun run smoke:ssh:preflight && APPALOFT_RUNTIME_USAGE_SSH_SMOKE=1 bun test --timeout=300000 packages/adapters/runtime/test/runtime-usage-smoke.test.ts",
    "smoke:runtime-usage": "bun run smoke:runtime-usage:docker && bun run smoke:runtime-usage:ssh",
    "smoke:capacity-prune:local": "APPALOFT_E2E_CAPACITY_PRUNE_LOCAL=true bun test --timeout=300000 packages/adapters/runtime/test/runtime-target-capacity-prune.test.ts",
    "smoke:capacity-prune:ssh": "bun run smoke:ssh:preflight && APPALOFT_E2E_SSH_CAPACITY_PRUNE=true bun test --timeout=300000 packages/adapters/runtime/test/runtime-target-capacity-prune.test.ts",
    "smoke:capacity-prune": "bun run smoke:capacity-prune:local && bun run smoke:capacity-prune:ssh",
    "smoke:preview-provider:github": "APPALOFT_GITHUB_PREVIEW_PROVIDER_SMOKE=true bun test --timeout=300000 packages/integrations/github/test/github-preview-provider-smoke.test.ts",
    "smoke:dependency-redis-backup": "APPALOFT_E2E_REDIS_BACKUP_RESTORE=true bun test --timeout=300000 ./apps/shell/test/e2e/dependency-resource-redis-backup.workflow.e2e.ts",
    "smoke:install-auth": "APPALOFT_INSTALL_FULL_SMOKE=1 bun test scripts/test/install-full-smoke.test.ts",
    "smoke:swarm": "APPALOFT_DOCKER_SWARM_SMOKE=1 APPALOFT_DOCKER_SWARM_SMOKE_TIMEOUT_MS=300000 bun test --timeout=300000 packages/adapters/runtime/test/docker-swarm-execution-backend.test.ts",
    "smoke:ssh:preflight": "bun run scripts/release/check-ssh-release-readiness.ts",
    "smoke:public-launch:basic-docker": "APPALOFT_PUBLIC_LAUNCH_SMOKE_SCENARIO=basic-docker bun run scripts/smoke/public-launch-smoke.ts",
    "smoke:public-launch:github-repo": "APPALOFT_PUBLIC_LAUNCH_SMOKE_SCENARIO=github-repo bun run scripts/smoke/public-launch-smoke.ts",
    "smoke:public-launch:scheduled-task-cron": "APPALOFT_PUBLIC_LAUNCH_SMOKE_SCENARIO=scheduled-task-cron bun run scripts/smoke/public-launch-smoke.ts",
    "smoke:public-launch": "bun run smoke:public-launch:basic-docker && bun run smoke:public-launch:github-repo && bun run smoke:public-launch:scheduled-task-cron",
    "smoke:ssh": "bun run smoke:public-launch",
    "smoke:public-launch:basic-docker:evidence": "bun run scripts/release/capture-ssh-smoke-evidence.ts --suite basic-docker --out dist/release/public-launch-basic-docker-evidence.json",
    "smoke:public-launch:github-repo:evidence": "bun run scripts/release/capture-ssh-smoke-evidence.ts --suite github-repo --out dist/release/public-launch-github-repo-evidence.json",
    "smoke:public-launch:scheduled-task-cron:evidence": "bun run scripts/release/capture-ssh-smoke-evidence.ts --suite scheduled-task-cron --out dist/release/public-launch-cron-evidence.json",
    "smoke:ssh:evidence": "bun run scripts/release/capture-ssh-smoke-evidence.ts",
    "smoke:ssh:evidence:verify": "bun run scripts/release/verify-ssh-smoke-evidence.ts",
    "smoke:public-launch:basic-docker:evidence:verify": "bun run scripts/release/verify-ssh-smoke-evidence.ts --suite basic-docker --path dist/release/public-launch-basic-docker-evidence.json",
    "smoke:public-launch:github-repo:evidence:verify": "bun run scripts/release/verify-ssh-smoke-evidence.ts --suite github-repo --path dist/release/public-launch-github-repo-evidence.json",
    "smoke:public-launch:scheduled-task-cron:evidence:verify": "bun run scripts/release/verify-ssh-smoke-evidence.ts --suite scheduled-task-cron --path dist/release/public-launch-cron-evidence.json",
    "prepare": "husky"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/*/*"
  ]
}
