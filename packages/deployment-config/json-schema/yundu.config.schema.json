{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Project name to reuse or create."
        },
        "description": {
          "description": "Optional project description.",
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["name"],
      "additionalProperties": false,
      "description": "Project bootstrap settings."
    },
    "environment": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Environment name to reuse or create."
        },
        "kind": {
          "description": "Environment kind. Defaults to custom when omitted.",
          "type": "string",
          "enum": ["local", "development", "test", "staging", "production", "preview", "custom"]
        }
      },
      "required": ["name"],
      "additionalProperties": false,
      "description": "Environment bootstrap settings."
    },
    "resource": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Resource name to reuse or create."
        },
        "kind": {
          "description": "Resource kind. Defaults to application.",
          "type": "string",
          "enum": [
            "application",
            "service",
            "database",
            "cache",
            "compose-stack",
            "worker",
            "static-site",
            "external"
          ]
        },
        "description": {
          "description": "Optional resource description.",
          "type": "string",
          "minLength": 1
        },
        "services": {
          "description": "Services contained by a compose-stack resource.",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "description": "Service name inside a compose-stack resource."
              },
              "kind": {
                "type": "string",
                "enum": ["web", "api", "worker", "database", "cache", "service"],
                "description": "Service role inside the resource."
              }
            },
            "required": ["name", "kind"],
            "additionalProperties": false,
            "description": "Service entry inside a resource."
          }
        }
      },
      "required": ["name"],
      "additionalProperties": false,
      "description": "Resource bootstrap settings."
    },
    "targets": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "key": {
                "description": "Stable target key for deployment.targetKey selection.",
                "type": "string",
                "minLength": 1
              },
              "name": {
                "description": "Deployment target display name.",
                "type": "string",
                "minLength": 1
              },
              "host": {
                "description": "Target host. Local shell defaults to 127.0.0.1 when omitted.",
                "type": "string",
                "minLength": 1
              },
              "port": {
                "description": "Target management port.",
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "destination": {
                "description": "Deployment destination or isolation boundary on the selected server.",
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "kind": {
                    "type": "string",
                    "enum": ["docker", "compose", "host-process", "generic"]
                  }
                },
                "additionalProperties": false
              },
              "providerKey": {
                "type": "string",
                "minLength": 1,
                "description": "Registered provider key, for example local-shell."
              }
            },
            "required": ["providerKey"],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "key": {
                "description": "Stable target key for deployment.targetKey selection.",
                "type": "string",
                "minLength": 1
              },
              "name": {
                "description": "Deployment target display name.",
                "type": "string",
                "minLength": 1
              },
              "host": {
                "description": "Target host. Local shell defaults to 127.0.0.1 when omitted.",
                "type": "string",
                "minLength": 1
              },
              "port": {
                "description": "Target management port.",
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "destination": {
                "description": "Deployment destination or isolation boundary on the selected server.",
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "kind": {
                    "type": "string",
                    "enum": ["docker", "compose", "host-process", "generic"]
                  }
                },
                "additionalProperties": false
              },
              "provider": {
                "type": "string",
                "minLength": 1,
                "description": "Alias for providerKey."
              }
            },
            "required": ["provider"],
            "additionalProperties": false
          }
        ],
        "description": "Deployment target bootstrap settings."
      }
    },
    "servers": {
      "description": "Alias for targets, kept for transport-compatible server wording.",
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "key": {
                "description": "Stable target key for deployment.targetKey selection.",
                "type": "string",
                "minLength": 1
              },
              "name": {
                "description": "Deployment target display name.",
                "type": "string",
                "minLength": 1
              },
              "host": {
                "description": "Target host. Local shell defaults to 127.0.0.1 when omitted.",
                "type": "string",
                "minLength": 1
              },
              "port": {
                "description": "Target management port.",
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "destination": {
                "description": "Deployment destination or isolation boundary on the selected server.",
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "kind": {
                    "type": "string",
                    "enum": ["docker", "compose", "host-process", "generic"]
                  }
                },
                "additionalProperties": false
              },
              "providerKey": {
                "type": "string",
                "minLength": 1,
                "description": "Registered provider key, for example local-shell."
              }
            },
            "required": ["providerKey"],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "key": {
                "description": "Stable target key for deployment.targetKey selection.",
                "type": "string",
                "minLength": 1
              },
              "name": {
                "description": "Deployment target display name.",
                "type": "string",
                "minLength": 1
              },
              "host": {
                "description": "Target host. Local shell defaults to 127.0.0.1 when omitted.",
                "type": "string",
                "minLength": 1
              },
              "port": {
                "description": "Target management port.",
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "destination": {
                "description": "Deployment destination or isolation boundary on the selected server.",
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "kind": {
                    "type": "string",
                    "enum": ["docker", "compose", "host-process", "generic"]
                  }
                },
                "additionalProperties": false
              },
              "provider": {
                "type": "string",
                "minLength": 1,
                "description": "Alias for providerKey."
              }
            },
            "required": ["provider"],
            "additionalProperties": false
          }
        ],
        "description": "Deployment target bootstrap settings."
      }
    },
    "deployment": {
      "type": "object",
      "properties": {
        "targetKey": {
          "description": "Configured target key, name, or provider alias to deploy to.",
          "type": "string",
          "minLength": 1
        },
        "target": {
          "description": "Alias for targetKey.",
          "type": "string",
          "minLength": 1
        },
        "method": {
          "description": "Requested deployment method.",
          "type": "string",
          "enum": ["auto", "dockerfile", "docker-compose", "prebuilt-image", "workspace-commands"]
        },
        "installCommand": {
          "type": "string",
          "minLength": 1
        },
        "buildCommand": {
          "type": "string",
          "minLength": 1
        },
        "startCommand": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "description": "Application port.",
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "healthCheckPath": {
          "type": "string",
          "minLength": 1
        },
        "healthPath": {
          "description": "Alias for healthCheckPath.",
          "type": "string",
          "minLength": 1
        },
        "proxy": {
          "description": "Edge proxy to configure for public domains. Defaults to traefik when domains are set.",
          "type": "string",
          "enum": ["none", "traefik", "caddy"]
        },
        "domain": {
          "description": "Single public domain alias.",
          "type": "string",
          "minLength": 1
        },
        "domains": {
          "description": "Public domains for access routing.",
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "pathPrefix": {
          "description": "Public route path prefix.",
          "type": "string",
          "minLength": 1
        },
        "tlsMode": {
          "description": "TLS handling for the public access route.",
          "type": "string",
          "enum": ["auto", "disabled"]
        }
      },
      "additionalProperties": false,
      "description": "Deployment command defaults."
    }
  },
  "additionalProperties": false,
  "description": "Yundu deployment config file."
}
