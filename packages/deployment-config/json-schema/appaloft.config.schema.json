{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "properties": {
        "baseDirectory": {
          "description": "Relative workspace directory to use as the deployable source root.",
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\/)(?![a-zA-Z][a-zA-Z0-9+.-]*:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))(?!.*[;&|`$<>]).+$"
        },
        "gitRef": {
          "description": "Git ref to record with the source profile.",
          "type": "string",
          "minLength": 1
        },
        "commitSha": {
          "description": "Immutable git commit SHA to record with the source profile.",
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "description": "Source profile fields. This object must not choose projects or resources."
    },
    "runtime": {
      "type": "object",
      "properties": {
        "strategy": {
          "description": "Requested runtime plan strategy.",
          "type": "string",
          "enum": [
            "auto",
            "dockerfile",
            "docker-compose",
            "prebuilt-image",
            "workspace-commands",
            "static"
          ]
        },
        "installCommand": {
          "type": "string",
          "minLength": 1
        },
        "buildCommand": {
          "type": "string",
          "minLength": 1
        },
        "startCommand": {
          "type": "string",
          "minLength": 1
        },
        "publishDirectory": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\/)(?![a-zA-Z][a-zA-Z0-9+.-]*:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))(?!.*[;&|`$<>]).+$"
        },
        "healthCheckPath": {
          "type": "string",
          "minLength": 1
        },
        "healthCheck": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "path": {
              "description": "HTTP path used for readiness checks.",
              "type": "string",
              "minLength": 1
            },
            "intervalSeconds": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "timeoutSeconds": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "retries": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "additionalProperties": false,
          "description": "Health-check profile fields."
        }
      },
      "additionalProperties": false,
      "description": "Runtime profile fields copied into resource creation for quick deploy."
    },
    "network": {
      "type": "object",
      "properties": {
        "internalPort": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "upstreamProtocol": {
          "type": "string",
          "enum": ["http", "tcp"]
        },
        "exposureMode": {
          "type": "string",
          "enum": ["none", "reverse-proxy", "direct-port"]
        },
        "targetServiceName": {
          "type": "string",
          "minLength": 1
        },
        "hostPort": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "additionalProperties": false,
      "description": "Network profile fields copied into resource creation for quick deploy."
    },
    "health": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "path": {
          "description": "HTTP path used for readiness checks.",
          "type": "string",
          "minLength": 1
        },
        "intervalSeconds": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "timeoutSeconds": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "retries": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "additionalProperties": false,
      "description": "Health-check profile fields."
    },
    "env": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          }
        ]
      }
    },
    "secrets": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1,
            "description": "Secret reference, for example environment-secret:database_url or server-credential:ssh_prod."
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["from"],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "description": "Appaloft repository deployment profile config file."
}
