{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "controlPlane": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["none", "auto", "cloud", "self-hosted"]
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["mode"],
      "additionalProperties": false,
      "description": "Non-secret control-plane connection policy. Identity and secrets stay outside config."
    },
    "source": {
      "type": "object",
      "properties": {
        "baseDirectory": {
          "description": "Relative workspace directory to use as the deployable source root.",
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\/)(?![a-zA-Z][a-zA-Z0-9+.-]*:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))(?!.*[;&|`$<>]).+$"
        },
        "gitRef": {
          "description": "Git ref to record with the source profile.",
          "type": "string",
          "minLength": 1
        },
        "commitSha": {
          "description": "Immutable git commit SHA to record with the source profile.",
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "description": "Source profile fields. This object must not choose projects or resources."
    },
    "runtime": {
      "type": "object",
      "properties": {
        "strategy": {
          "description": "Requested runtime plan strategy.",
          "type": "string",
          "enum": [
            "auto",
            "dockerfile",
            "docker-compose",
            "prebuilt-image",
            "workspace-commands",
            "static"
          ]
        },
        "installCommand": {
          "type": "string",
          "minLength": 1
        },
        "buildCommand": {
          "type": "string",
          "minLength": 1
        },
        "startCommand": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "publishDirectory": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\/)(?![a-zA-Z][a-zA-Z0-9+.-]*:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))(?!.*[;&|`$<>]).+$"
        },
        "dockerfilePath": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\/)(?![a-zA-Z][a-zA-Z0-9+.-]*:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))(?!.*[;&|`$<>]).+$"
        },
        "dockerComposeFilePath": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\/)(?![a-zA-Z][a-zA-Z0-9+.-]*:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))(?!.*[;&|`$<>]).+$"
        },
        "buildTarget": {
          "type": "string",
          "minLength": 1
        },
        "healthCheckPath": {
          "type": "string",
          "minLength": 1
        },
        "healthCheck": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "path": {
              "description": "HTTP path used for readiness checks.",
              "type": "string",
              "minLength": 1
            },
            "intervalSeconds": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "timeoutSeconds": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "retries": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "additionalProperties": false,
          "description": "Health-check profile fields."
        }
      },
      "additionalProperties": false,
      "description": "Runtime profile fields copied into resource creation for quick deploy."
    },
    "network": {
      "type": "object",
      "properties": {
        "internalPort": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "upstreamProtocol": {
          "type": "string",
          "enum": ["http", "tcp"]
        },
        "exposureMode": {
          "type": "string",
          "enum": ["none", "reverse-proxy", "direct-port"]
        },
        "targetServiceName": {
          "type": "string",
          "minLength": 1
        },
        "hostPort": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "additionalProperties": false,
      "description": "Network profile fields copied into resource creation for quick deploy."
    },
    "health": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "path": {
          "description": "HTTP path used for readiness checks.",
          "type": "string",
          "minLength": 1
        },
        "intervalSeconds": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "timeoutSeconds": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "retries": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "additionalProperties": false,
      "description": "Health-check profile fields."
    },
    "access": {
      "type": "object",
      "properties": {
        "domains": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string",
                "minLength": 1
              },
              "pathPrefix": {
                "type": "string"
              },
              "tlsMode": {
                "default": "auto",
                "type": "string",
                "enum": ["auto", "disabled"]
              },
              "redirectTo": {
                "type": "string",
                "minLength": 1
              },
              "redirectStatus": {
                "anyOf": [
                  {
                    "type": "number",
                    "const": 301
                  },
                  {
                    "type": "number",
                    "const": 302
                  },
                  {
                    "type": "number",
                    "const": 307
                  },
                  {
                    "type": "number",
                    "const": 308
                  }
                ]
              }
            },
            "required": ["host", "pathPrefix", "tlsMode"],
            "additionalProperties": false,
            "description": "Provider-neutral server-applied domain intent."
          }
        }
      },
      "required": ["domains"],
      "additionalProperties": false,
      "description": "Access intent resolved outside deployments.create."
    },
    "env": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          }
        ]
      }
    },
    "secrets": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1,
            "description": "Secret reference, for example environment-secret:database_url or server-credential:ssh_prod."
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["from"],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "description": "Appaloft repository deployment profile config file."
}
