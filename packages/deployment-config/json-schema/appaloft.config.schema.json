{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "controlPlane": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["none", "auto", "cloud", "self-hosted"]
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "deploymentContext": {
          "description": "Non-secret deployment identity for explicitly bootstrapping or relinking this repository to an Appaloft server context.",
          "type": "object",
          "properties": {
            "projectId": {
              "type": "string",
              "minLength": 1
            },
            "environmentId": {
              "type": "string",
              "minLength": 1
            },
            "resourceId": {
              "type": "string",
              "minLength": 1
            },
            "serverId": {
              "type": "string",
              "minLength": 1
            },
            "destinationId": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["projectId", "environmentId", "resourceId", "serverId"],
          "additionalProperties": false
        },
        "install": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "minLength": 1
            },
            "domain": {
              "type": "string",
              "minLength": 1
            },
            "database": {
              "type": "string",
              "enum": ["postgres", "pglite"]
            },
            "orchestrator": {
              "type": "string",
              "enum": ["compose", "swarm"]
            },
            "proxy": {
              "type": "string",
              "enum": ["traefik", "none"]
            },
            "httpHost": {
              "type": "string",
              "minLength": 1
            },
            "httpPort": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "installDir": {
              "type": "string",
              "minLength": 1
            },
            "composeProjectName": {
              "type": "string",
              "minLength": 1
            },
            "swarmStackName": {
              "type": "string",
              "minLength": 1
            },
            "swarmInit": {
              "type": "boolean"
            },
            "swarmAdvertiseAddr": {
              "type": "string",
              "minLength": 1
            },
            "image": {
              "type": "string",
              "minLength": 1
            },
            "installerUrl": {
              "type": "string",
              "minLength": 1
            },
            "skipDockerInstall": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "required": ["mode"],
      "additionalProperties": false,
      "description": "Non-secret control-plane connection policy. Identity and secrets stay outside config."
    },
    "source": {
      "type": "object",
      "properties": {
        "type": {
          "description": "Repository source kind.",
          "type": "string",
          "const": "git"
        },
        "repository": {
          "description": "Git repository URL to deploy from.",
          "type": "string",
          "minLength": 1
        },
        "baseDirectory": {
          "description": "Relative workspace directory to use as the deployable source root.",
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\/)(?![a-zA-Z][a-zA-Z0-9+.-]*:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))(?!.*[;&|`$<>]).+$"
        },
        "gitRef": {
          "description": "Git ref to record with the source profile.",
          "type": "string",
          "minLength": 1
        },
        "commitSha": {
          "description": "Immutable git commit SHA to record with the source profile.",
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "description": "Source profile fields. This object must not choose projects or resources."
    },
    "runtime": {
      "type": "object",
      "properties": {
        "type": {
          "description": "Application runtime type shorthand.",
          "type": "string",
          "const": "node"
        },
        "strategy": {
          "description": "Requested runtime plan strategy.",
          "type": "string",
          "enum": [
            "auto",
            "dockerfile",
            "docker-compose",
            "prebuilt-image",
            "workspace-commands",
            "static"
          ]
        },
        "installCommand": {
          "type": "string",
          "minLength": 1
        },
        "buildCommand": {
          "type": "string",
          "minLength": 1
        },
        "startCommand": {
          "type": "string",
          "minLength": 1
        },
        "build": {
          "type": "object",
          "properties": {
            "command": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["command"],
          "additionalProperties": false
        },
        "start": {
          "type": "object",
          "properties": {
            "command": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["command"],
          "additionalProperties": false
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "publishDirectory": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\/)(?![a-zA-Z][a-zA-Z0-9+.-]*:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))(?!.*[;&|`$<>]).+$"
        },
        "dockerfilePath": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\/)(?![a-zA-Z][a-zA-Z0-9+.-]*:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))(?!.*[;&|`$<>]).+$"
        },
        "dockerComposeFilePath": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\/)(?![a-zA-Z][a-zA-Z0-9+.-]*:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))(?!.*[;&|`$<>]).+$"
        },
        "buildTarget": {
          "type": "string",
          "minLength": 1
        },
        "healthCheckPath": {
          "type": "string",
          "minLength": 1
        },
        "healthCheck": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "path": {
              "description": "HTTP path used for readiness checks.",
              "type": "string",
              "minLength": 1
            },
            "intervalSeconds": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "timeoutSeconds": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "retries": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "additionalProperties": false,
          "description": "Health-check profile fields."
        }
      },
      "additionalProperties": false,
      "description": "Runtime profile fields copied into resource creation for quick deploy."
    },
    "network": {
      "type": "object",
      "properties": {
        "internalPort": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "upstreamProtocol": {
          "type": "string",
          "enum": ["http", "tcp"]
        },
        "exposureMode": {
          "type": "string",
          "enum": ["none", "reverse-proxy", "direct-port"]
        },
        "targetServiceName": {
          "type": "string",
          "minLength": 1
        },
        "hostPort": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "additionalProperties": false,
      "description": "Network profile fields copied into resource creation for quick deploy."
    },
    "retention": {
      "type": "object",
      "properties": {
        "runtimePrune": {
          "type": "object",
          "properties": {
            "retentionDays": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "destructive": {
              "default": false,
              "type": "boolean"
            },
            "categories": {
              "default": ["stopped-containers"],
              "minItems": 1,
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "stopped-containers",
                  "preview-workspaces",
                  "source-workspaces",
                  "docker-build-cache",
                  "unused-images",
                  "remote-state-markers"
                ]
              }
            },
            "retryOnFailure": {
              "default": true,
              "type": "boolean"
            },
            "enabled": {
              "default": true,
              "type": "boolean"
            }
          },
          "required": ["retentionDays", "destructive", "categories", "retryOnFailure", "enabled"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false,
      "description": "Safe retention policy fields materialized during deployment config bootstrap."
    },
    "health": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "path": {
          "description": "HTTP path used for readiness checks.",
          "type": "string",
          "minLength": 1
        },
        "intervalSeconds": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "timeoutSeconds": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "retries": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "additionalProperties": false,
      "description": "Health-check profile fields."
    },
    "access": {
      "type": "object",
      "properties": {
        "domains": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string",
                "minLength": 1
              },
              "pathPrefix": {
                "type": "string"
              },
              "tlsMode": {
                "default": "auto",
                "type": "string",
                "enum": ["auto", "disabled"]
              },
              "redirectTo": {
                "type": "string",
                "minLength": 1
              },
              "redirectStatus": {
                "anyOf": [
                  {
                    "type": "number",
                    "const": 301
                  },
                  {
                    "type": "number",
                    "const": 302
                  },
                  {
                    "type": "number",
                    "const": 307
                  },
                  {
                    "type": "number",
                    "const": 308
                  }
                ]
              }
            },
            "required": ["host", "pathPrefix", "tlsMode"],
            "additionalProperties": false,
            "description": "Provider-neutral server-applied domain intent."
          }
        }
      },
      "required": ["domains"],
      "additionalProperties": false,
      "description": "Access intent resolved outside deployments.create."
    },
    "preview": {
      "type": "object",
      "properties": {
        "pullRequest": {
          "type": "object",
          "properties": {
            "domainTemplate": {
              "type": "string",
              "minLength": 1
            },
            "tlsMode": {
              "type": "string",
              "enum": ["auto", "disabled"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false,
      "description": "Preview deployment policy read by trusted entrypoints such as GitHub Actions."
    },
    "dependencies": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_-]{0,62}$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["postgres", "redis", "mysql", "clickhouse", "object-storage", "opensearch"],
            "description": "Application dependency kind."
          },
          "source": {
            "type": "string",
            "const": "managed",
            "description": "Managed dependencies are created by Appaloft."
          },
          "bind": {
            "type": "object",
            "properties": {
              "env": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Z_][A-Z0-9_]*$",
                "description": "Runtime environment variable target for this dependency."
              }
            },
            "required": ["env"],
            "additionalProperties": false
          },
          "backup": {
            "type": "object",
            "properties": {
              "enabled": {
                "default": true,
                "type": "boolean"
              },
              "intervalHours": {
                "type": "integer",
                "minimum": 1,
                "maximum": 8760
              },
              "retentionDays": {
                "type": "integer",
                "minimum": 1,
                "maximum": 3650
              },
              "retryOnFailure": {
                "default": true,
                "type": "boolean"
              }
            },
            "required": ["enabled", "retryOnFailure"],
            "additionalProperties": false,
            "description": "User-facing dependency resource scheduled backup policy declaration."
          },
          "preview": {
            "type": "object",
            "properties": {
              "lifecycle": {
                "type": "string",
                "const": "ephemeral"
              }
            },
            "additionalProperties": false
          }
        },
        "required": ["kind", "source", "bind"],
        "additionalProperties": false,
        "description": "User-facing application dependency declaration."
      }
    },
    "storage": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_-]{0,62}$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "const": "volume",
            "description": "Application storage dependency kind."
          },
          "source": {
            "type": "string",
            "const": "managed",
            "description": "Managed storage volumes are created by Appaloft."
          },
          "mount": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "description": "Absolute workload path that receives this storage volume."
              },
              "mode": {
                "default": "read-write",
                "type": "string",
                "enum": ["read-write", "read-only"]
              }
            },
            "required": ["path", "mode"],
            "additionalProperties": false
          },
          "preview": {
            "type": "object",
            "properties": {
              "lifecycle": {
                "type": "string",
                "const": "ephemeral"
              }
            },
            "additionalProperties": false
          }
        },
        "required": ["kind", "source", "mount"],
        "additionalProperties": false,
        "description": "User-facing application storage declaration."
      }
    },
    "scheduledTasks": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_-]{0,62}$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "schedule": {
            "type": "string",
            "minLength": 1,
            "description": "Safe scheduled task schedule expression."
          },
          "timezone": {
            "default": "UTC",
            "type": "string",
            "minLength": 1
          },
          "command": {
            "type": "string",
            "minLength": 1,
            "description": "Single-line scheduled task command intent."
          },
          "timeoutSeconds": {
            "default": 3600,
            "type": "integer",
            "minimum": 1,
            "maximum": 86400
          },
          "retryLimit": {
            "default": 0,
            "type": "integer",
            "minimum": 0,
            "maximum": 10
          },
          "concurrencyPolicy": {
            "default": "forbid",
            "type": "string",
            "enum": ["forbid"]
          },
          "status": {
            "default": "enabled",
            "type": "string",
            "enum": ["enabled", "disabled"]
          },
          "preview": {
            "type": "object",
            "properties": {
              "lifecycle": {
                "type": "string",
                "const": "ephemeral"
              }
            },
            "additionalProperties": false
          }
        },
        "required": [
          "schedule",
          "timezone",
          "command",
          "timeoutSeconds",
          "retryLimit",
          "concurrencyPolicy",
          "status"
        ],
        "additionalProperties": false,
        "description": "User-facing Resource scheduled task declaration."
      }
    },
    "autoDeploy": {
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "type": "boolean"
        },
        "trigger": {
          "default": "git-push",
          "type": "string",
          "const": "git-push"
        },
        "refs": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "events": {
          "default": ["push"],
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["push", "tag"]
          }
        },
        "dedupeWindowSeconds": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 86400
        }
      },
      "required": ["enabled", "trigger", "events"],
      "additionalProperties": false,
      "description": "User-facing Resource auto-deploy policy declaration."
    },
    "env": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          }
        ]
      }
    },
    "secrets": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1,
            "description": "Secret reference, for example environment-secret:database_url or server-credential:ssh_prod."
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["from"],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "description": "Appaloft repository deployment profile config file."
}
