// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`CaddyEdgeProxyProvider [ASH-PROVIDER-002] snapshots rendered proxy shell commands 1`] = `
{
  "diagnostics": [
    {
      "command": 
"actual="$(docker inspect -f 'status={{.State.Status}} image={{.Config.Image}}' 'appaloft-caddy' 2>/dev/null)"
printf "%s\\n" "$actual"
[ "$actual" = 'status=running image=lucaslorentz/caddy-docker-proxy:2.9-alpine' ]"
,
      "name": "edge-proxy-container",
    },
    {
      "command": 
"logs="$(docker logs --tail 80 'appaloft-caddy' 2>&1 || true)"
printf "%s\\n" "$logs" | tail -n 20
! printf "%s\\n" "$logs" | grep -E 'ERROR|Error|failed|Failed'"
,
      "name": "edge-proxy-provider-logs",
    },
  ],
  "ensure": {
    "containerCommand": "docker inspect -f '{{.State.Running}}' 'appaloft-caddy' 2>/dev/null | grep true >/dev/null || (docker rm -f 'appaloft-caddy' >/dev/null 2>&1 || true; docker run -d --restart unless-stopped --name 'appaloft-caddy' --network 'appaloft-edge' -p '8080:80' -p '8443:443' -v /var/run/docker.sock:/var/run/docker.sock -v appaloft-caddy-data:/data -v appaloft-caddy-config:/config -e 'CADDY_INGRESS_NETWORKS=appaloft-edge' 'lucaslorentz/caddy-docker-proxy:2.9-alpine' )",
    "networkCommand": "docker network inspect 'appaloft-edge' >/dev/null 2>&1 || docker network create 'appaloft-edge'",
  },
}
`;
