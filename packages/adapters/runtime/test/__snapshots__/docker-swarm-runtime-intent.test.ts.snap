// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`renderDockerSwarmRuntimeIntent [BP-COMP-REL-RUNTIME-002][SWARM-COMP-REL-RUNTIME-001] renders Blueprint component relation runtime effects into Swarm intent 1`] = `
[
  {
    "command": "echo 'Waiting for api.internal before worker-starts-after-api'; until docker service ps --filter 'desired-state=running' 'api.internal' | grep -q .; do sleep 2; done",
    "displayCommand": "echo 'Waiting for api.internal before worker-starts-after-api'; until docker service ps --filter 'desired-state=running' 'api.internal' | grep -q .; do sleep 2; done",
    "step": "wait-for-component-readiness",
  },
  {
    "command": "docker service create --name 'appaloft-res-worker-dst-prod-dep-worker_web' --label 'appaloft.component-id=worker' --label 'appaloft.component-link.worker-starts-after-api.network=appaloft-blueprint-private' --label 'appaloft.component-link.worker-starts-after-api.provider=api' --label 'appaloft.component-link.worker-starts-after-api.readiness=healthy' --label 'appaloft.component-link.worker-starts-after-api.required=true' --label 'appaloft.component-link.worker-starts-after-api.service=api.internal' --label 'appaloft.component-link.worker-traces-to-jaeger.endpoint=otlp-grpc' --label 'appaloft.component-link.worker-traces-to-jaeger.network=appaloft-blueprint-private' --label 'appaloft.component-link.worker-traces-to-jaeger.provider=jaeger' --label 'appaloft.component-link.worker-traces-to-jaeger.required=false' --label 'appaloft.component-link.worker-traces-to-jaeger.service=jaeger.internal' --label 'appaloft.component-link.worker-traces-to-jaeger.telemetry=traces' --label 'appaloft.component-link.worker-uses-api.endpoint=http' --label 'appaloft.component-link.worker-uses-api.network=appaloft-blueprint-private' --label 'appaloft.component-link.worker-uses-api.provider=api' --label 'appaloft.component-link.worker-uses-api.required=true' --label 'appaloft.component-link.worker-uses-api.service=api.internal' --label 'appaloft.component-service=worker.internal' --label 'appaloft.deployment-id=dep_worker' --label 'appaloft.destination-id=dst_prod' --label 'appaloft.managed=true' --label 'appaloft.resource-id=res_worker' --label 'appaloft.runtime-target=docker-swarm' --label 'appaloft.target-id=dtg_swarm_1' --network 'appaloft-blueprint-private' --network 'appaloft-edge' --env 'API_BASE_URL=http://api.internal:3000' --env 'OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=grpc://jaeger.internal:4317' --health-cmd 'wget -q -O- http://127.0.0.1:3000/healthz >/dev/null' --health-interval '10s' --health-timeout '5s' --health-retries '3' --health-start-period '0s' 'registry.example.com/team/app:sha'",
    "displayCommand": "docker service create --name 'appaloft-res-worker-dst-prod-dep-worker_web' --label 'appaloft.component-id=worker' --label 'appaloft.component-link.worker-starts-after-api.network=appaloft-blueprint-private' --label 'appaloft.component-link.worker-starts-after-api.provider=api' --label 'appaloft.component-link.worker-starts-after-api.readiness=healthy' --label 'appaloft.component-link.worker-starts-after-api.required=true' --label 'appaloft.component-link.worker-starts-after-api.service=api.internal' --label 'appaloft.component-link.worker-traces-to-jaeger.endpoint=otlp-grpc' --label 'appaloft.component-link.worker-traces-to-jaeger.network=appaloft-blueprint-private' --label 'appaloft.component-link.worker-traces-to-jaeger.provider=jaeger' --label 'appaloft.component-link.worker-traces-to-jaeger.required=false' --label 'appaloft.component-link.worker-traces-to-jaeger.service=jaeger.internal' --label 'appaloft.component-link.worker-traces-to-jaeger.telemetry=traces' --label 'appaloft.component-link.worker-uses-api.endpoint=http' --label 'appaloft.component-link.worker-uses-api.network=appaloft-blueprint-private' --label 'appaloft.component-link.worker-uses-api.provider=api' --label 'appaloft.component-link.worker-uses-api.required=true' --label 'appaloft.component-link.worker-uses-api.service=api.internal' --label 'appaloft.component-service=worker.internal' --label 'appaloft.deployment-id=dep_worker' --label 'appaloft.destination-id=dst_prod' --label 'appaloft.managed=true' --label 'appaloft.resource-id=res_worker' --label 'appaloft.runtime-target=docker-swarm' --label 'appaloft.target-id=dtg_swarm_1' --network 'appaloft-blueprint-private' --network 'appaloft-edge' --env 'API_BASE_URL=********' --env 'OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=********' --health-cmd 'wget -q -O- http://127.0.0.1:3000/healthz >/dev/null' --health-interval '10s' --health-timeout '5s' --health-retries '3' --health-start-period '0s' 'registry.example.com/team/app:sha'",
    "step": "create-candidate-service",
  },
  {
    "command": "service_name='appaloft-res-worker-dst-prod-dep-worker_web'; attempt=0; max_attempts=50; while [ "$attempt" -lt "$max_attempts" ]; do desired_replicas=$(docker service inspect "$service_name" --format '{{if .Spec.Mode.Replicated}}{{.Spec.Mode.Replicated.Replicas}}{{else}}-1{{end}}') || exit 1; if [ "$desired_replicas" -lt 0 ]; then desired_replicas=$(docker service ps "$service_name" --filter 'desired-state=running' --format '{{.ID}}' | wc -l | tr -d ' '); fi; running_count=$(docker service ps "$service_name" --filter 'desired-state=running' --format '{{.CurrentState}}' | awk '$1 == "Running" { count += 1 } END { print count + 0 }') || exit 1; if [ "$desired_replicas" -gt 0 ] && [ "$running_count" -eq "$desired_replicas" ]; then break; fi; attempt=$((attempt + 1)); sleep 1; done; if [ "$desired_replicas" -le 0 ] || [ "$running_count" -ne "$desired_replicas" ]; then docker service ps --no-trunc "$service_name"; exit 1; fi; docker service inspect 'appaloft-res-worker-dst-prod-dep-worker_web' --format '{{range .Spec.TaskTemplate.ContainerSpec.Env}}{{println .}}{{end}}' | sed 's/=.*//' | grep -Fqx -- 'API_BASE_URL' && docker service inspect 'appaloft-res-worker-dst-prod-dep-worker_web' --format '{{range .Spec.TaskTemplate.ContainerSpec.Env}}{{println .}}{{end}}' | sed 's/=.*//' | grep -Fqx -- 'OTEL_EXPORTER_OTLP_TRACES_ENDPOINT'",
    "displayCommand": "service_name='appaloft-res-worker-dst-prod-dep-worker_web'; attempt=0; max_attempts=50; while [ "$attempt" -lt "$max_attempts" ]; do desired_replicas=$(docker service inspect "$service_name" --format '{{if .Spec.Mode.Replicated}}{{.Spec.Mode.Replicated.Replicas}}{{else}}-1{{end}}') || exit 1; if [ "$desired_replicas" -lt 0 ]; then desired_replicas=$(docker service ps "$service_name" --filter 'desired-state=running' --format '{{.ID}}' | wc -l | tr -d ' '); fi; running_count=$(docker service ps "$service_name" --filter 'desired-state=running' --format '{{.CurrentState}}' | awk '$1 == "Running" { count += 1 } END { print count + 0 }') || exit 1; if [ "$desired_replicas" -gt 0 ] && [ "$running_count" -eq "$desired_replicas" ]; then break; fi; attempt=$((attempt + 1)); sleep 1; done; if [ "$desired_replicas" -le 0 ] || [ "$running_count" -ne "$desired_replicas" ]; then docker service ps --no-trunc "$service_name"; exit 1; fi; docker service inspect 'appaloft-res-worker-dst-prod-dep-worker_web' --format '{{range .Spec.TaskTemplate.ContainerSpec.Env}}{{println .}}{{end}}' | sed 's/=.*//' | grep -Fqx -- 'API_BASE_URL' && docker service inspect 'appaloft-res-worker-dst-prod-dep-worker_web' --format '{{range .Spec.TaskTemplate.ContainerSpec.Env}}{{println .}}{{end}}' | sed 's/=.*//' | grep -Fqx -- 'OTEL_EXPORTER_OTLP_TRACES_ENDPOINT'",
    "step": "verify-candidate-service",
  },
  {
    "command": "docker service update --label-add 'appaloft.route-candidate=ready' --label-add 'traefik.enable=true' --label-add 'traefik.docker.network=appaloft-edge' --label-add 'traefik.http.routers.appaloft-res-worker-dst-prod-dep-worker-web.rule=Host(\`pr-1.example.com\`)' --label-add 'traefik.http.routers.appaloft-res-worker-dst-prod-dep-worker-web.entrypoints=websecure' --label-add 'traefik.http.routers.appaloft-res-worker-dst-prod-dep-worker-web.tls=true' --label-add 'traefik.http.routers.appaloft-res-worker-dst-prod-dep-worker-web.tls.certresolver=appaloft' --label-add 'traefik.http.routers.appaloft-res-worker-dst-prod-dep-worker-web.service=appaloft-res-worker-dst-prod-dep-worker-web-svc' --label-add 'traefik.http.services.appaloft-res-worker-dst-prod-dep-worker-web-svc.loadbalancer.server.port=3000' --label-add 'appaloft.route-target=active' 'appaloft-res-worker-dst-prod-dep-worker_web'",
    "displayCommand": "docker service update --label-add 'appaloft.route-candidate=ready' --label-add 'traefik.enable=true' --label-add 'traefik.docker.network=appaloft-edge' --label-add 'traefik.http.routers.appaloft-res-worker-dst-prod-dep-worker-web.rule=Host(\`pr-1.example.com\`)' --label-add 'traefik.http.routers.appaloft-res-worker-dst-prod-dep-worker-web.entrypoints=websecure' --label-add 'traefik.http.routers.appaloft-res-worker-dst-prod-dep-worker-web.tls=true' --label-add 'traefik.http.routers.appaloft-res-worker-dst-prod-dep-worker-web.tls.certresolver=appaloft' --label-add 'traefik.http.routers.appaloft-res-worker-dst-prod-dep-worker-web.service=appaloft-res-worker-dst-prod-dep-worker-web-svc' --label-add 'traefik.http.services.appaloft-res-worker-dst-prod-dep-worker-web-svc.loadbalancer.server.port=3000' --label-add 'appaloft.route-target=active' 'appaloft-res-worker-dst-prod-dep-worker_web'",
    "step": "promote-route-target",
  },
  {
    "command": "docker service ls -q --filter 'label=appaloft.destination-id=dst_prod' --filter 'label=appaloft.managed=true' --filter 'label=appaloft.resource-id=res_worker' --filter 'label=appaloft.runtime-target=docker-swarm' | while read -r service_id; do current_deployment=$(docker service inspect "$service_id" --format '{{ index .Spec.Labels "appaloft.deployment-id" }}'); if [ "$current_deployment" != 'dep_worker' ]; then stack_name=$(docker service inspect "$service_id" --format '{{ index .Spec.Labels "com.docker.stack.namespace" }}'); if [ -n "$stack_name" ] && [ "$stack_name" != "<no value>" ]; then docker stack rm "$stack_name"; else docker service rm "$service_id"; fi; fi; done",
    "displayCommand": "docker service ls -q --filter 'label=appaloft.destination-id=dst_prod' --filter 'label=appaloft.managed=true' --filter 'label=appaloft.resource-id=res_worker' --filter 'label=appaloft.runtime-target=docker-swarm' | while read -r service_id; do current_deployment=$(docker service inspect "$service_id" --format '{{ index .Spec.Labels "appaloft.deployment-id" }}'); if [ "$current_deployment" != 'dep_worker' ]; then stack_name=$(docker service inspect "$service_id" --format '{{ index .Spec.Labels "com.docker.stack.namespace" }}'); if [ -n "$stack_name" ] && [ "$stack_name" != "<no value>" ]; then docker stack rm "$stack_name"; else docker service rm "$service_id"; fi; fi; done",
    "step": "cleanup-superseded-services",
  },
]
`;
