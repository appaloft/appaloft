// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`SSH runtime environment files [DEP-BIND-SECRET-RESOLVE-005] renders shell exports with safe quoting 1`] = `
"# Generated by Appaloft. Contains deployment runtime environment.
export APPALOFT_DEPLOYMENT_ID='dep_123'
export DATABASE_URL='postgres://user:p'\\''ass@example.test/db'
export PORT='3000'
"
`;

exports[`SSH runtime environment files renders private remote write command and redacts encoded payload 1`] = `"mkdir -p '/srv/app/.appaloft' && tmp="$(mktemp '/srv/app/.appaloft/runtime.env.tmp.XXXXXX')" && trap 'rm -f "$tmp"' 0 && printf %s 'ZXhwb3J0IERBVEFCQVNFX1VSTD0ncG9zdGdyZXM6Ly9zZWNyZXQnCg==' | base64 -d > "$tmp" && chmod 600 "$tmp" && mv "$tmp" '/srv/app/.appaloft/runtime.env' && trap - 0"`;

exports[`SSH runtime environment files wraps remote compose commands after loading the runtime environment file 1`] = `
{
  "optional": 
"{ if [ -f '/srv/app/.appaloft/runtime.env' ]; then . '/srv/app/.appaloft/runtime.env'; fi; } && {
docker compose down
}"
,
  "required": 
"{ . '/srv/app/.appaloft/runtime.env'; } && {
docker compose up -d
}"
,
}
`;
