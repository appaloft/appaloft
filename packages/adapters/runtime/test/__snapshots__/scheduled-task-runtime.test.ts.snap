// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`RuntimeTargetScheduledTaskRuntimePort [SCHED-TASK-RUNTIME-002] renders Docker container task commands inside the resource runtime network namespace 1`] = `"docker rm -f 'appaloft-task-str_manual' >/dev/null 2>&1 || true; docker inspect 'appaloft-api' >/dev/null; docker run --rm --name 'appaloft-task-str_manual' --network 'container:appaloft-api' --env 'API_TOKEN=abc123' 'registry.example.com/app:dep_live' sh -lc 'bun run migrate'"`;

exports[`RuntimeTargetScheduledTaskRuntimePort [SCHED-TASK-RUNTIME-002] renders Docker Compose task commands against the target service 1`] = `"docker compose -p 'appaloft-dep-live' -f '/srv/app/compose.yml' run --rm --no-deps --env 'API_TOKEN=abc123' --workdir '/app' 'api' sh -lc 'bun run migrate'"`;

exports[`RuntimeTargetScheduledTaskRuntimePort [SCHED-TASK-RUNTIME-002] renders Docker Swarm task commands as one-off job services 1`] = `"docker service rm 'appaloft-task-str-swarm' >/dev/null 2>&1 || true; docker service inspect 'appaloft-res-api-dst-prod-dep-live_web' >/dev/null; docker service create --name 'appaloft-task-str-swarm' --restart-condition none --mode replicated-job --network 'appaloft-edge' --label 'appaloft.scheduled-task-run-id=str_swarm' --env 'API_TOKEN=abc123' 'registry.example.com/app:dep_live' sh -lc 'bun run migrate' >/dev/null; i=0; while [ "$i" -lt 600 ]; do state=$(docker service ps --format '{{.CurrentState}}' 'appaloft-task-str-swarm' | head -n 1); case "$state" in Complete*) break ;; Failed*|Rejected*) docker service ps --no-trunc 'appaloft-task-str-swarm' >&2; docker service logs 'appaloft-task-str-swarm'; docker service rm 'appaloft-task-str-swarm' >/dev/null 2>&1 || true; exit 1 ;; esac; i=$((i + 1)); sleep 1; done; if [ "$i" -ge 600 ]; then docker service ps --no-trunc 'appaloft-task-str-swarm' >&2; docker service rm 'appaloft-task-str-swarm' >/dev/null 2>&1 || true; exit 124; fi; docker service logs 'appaloft-task-str-swarm'; docker service rm 'appaloft-task-str-swarm' >/dev/null 2>&1 || true"`;
