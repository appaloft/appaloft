// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`RuntimeResourceRuntimeLogReader waits for process output before closing bounded local Docker logs 1`] = `
[
  "docker",
  "logs",
  "--tail",
  "25",
  "appaloft-dep_web",
]
`;

exports[`RuntimeResourceRuntimeLogReader opens generic SSH Docker container logs on the remote target 1`] = `
[
  "ssh",
  "-p",
  "2222",
  "-i",
  "<identity-file>",
  "-o",
  "IdentitiesOnly=yes",
  "-o",
  "BatchMode=yes",
  "-o",
  "PreferredAuthentications=publickey",
  "-o",
  "PasswordAuthentication=no",
  "-o",
  "KbdInteractiveAuthentication=no",
  "-o",
  "NumberOfPasswordPrompts=0",
  "-o",
  "StrictHostKeyChecking=accept-new",
  "-o",
  "ControlMaster=auto",
  "-o",
  "ControlPersist=120s",
  "-o",
  "ControlPath=<control-path>",
  "deployer@203.0.113.10",
  "docker logs --tail '25' --follow 'appaloft-dep_web'",
]
`;
