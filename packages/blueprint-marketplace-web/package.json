{
  "name": "@appaloft/blueprint-marketplace-web",
  "version": "0.0.0",
  "description": "Neutral Blueprint catalog marketplace components for Appaloft web surfaces.",
  "license": "Apache-2.0",
  "type": "module",
  "svelte": "./src/index.ts",
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./BlueprintMarketplacePage.svelte": {
      "svelte": "./src/BlueprintMarketplacePage.svelte",
      "types": "./src/BlueprintMarketplacePage.svelte",
      "default": "./src/BlueprintMarketplacePage.svelte"
    },
    "./BlueprintMarketplaceCard.svelte": {
      "svelte": "./src/BlueprintMarketplaceCard.svelte",
      "types": "./src/BlueprintMarketplaceCard.svelte",
      "default": "./src/BlueprintMarketplaceCard.svelte"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./url": {
      "types": "./src/url.ts",
      "default": "./src/url.ts"
    }
  },
  "peerDependencies": {
    "svelte": "^5.55.5"
  },
  "dependencies": {
    "@appaloft/blueprints": "workspace:*",
    "@appaloft/ui": "workspace:*",
    "boneyard-js": "^1.9.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@typescript/native": "npm:typescript@7.0.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "lint": "biome check .",
    "test": "vitest --run",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  }
}
